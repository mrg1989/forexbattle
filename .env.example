# ── OANDA (already configured) ───────────────────────────────────────────────
OANDA_TOKEN=your_oanda_practice_token
OANDA_ACCOUNT=your_oanda_account_id

# ── Anthropic (optional — AI analysis panel) ──────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Supabase / PostgreSQL (Stage 2+) ─────────────────────────────────────────
#
# DATABASE_URL  — Transaction pooler URL (used at runtime by PrismaClient)
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#   Found in: Supabase Dashboard → Project Settings → Database → Connection string → Transaction
#
# DIRECT_URL    — Direct connection URL (used by Prisma CLI for migrations/schema push)
#   Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
#   Found in: Supabase Dashboard → Project Settings → Database → Connection string → URI
#
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
